DATABASE_URL=postgresql://user@localhost:5432/surepath
JWT_SECRET=change-this-to-a-random-string
ADMIN_USER=admin
ADMIN_PASS=change-this
PORT=3000
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_MAPS_API_KEY=AIza...
HF_API_TOKEN=hf_...
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+27XXXXXXXXX
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
SERVER_HOST=surepath.co.za

# ─── Property Data Strategy ─────────────────────────────────────
# Priority: DeedsWeb (R18/query, full data) → GVR (free, municipal data) → skip gracefully
#
# GVR Collection (no credentials needed — public municipal data)
# Provides: owner name, municipal value, zoning, stand size — FREE
GVR_ENABLED=true
GVR_METROS=cape_town,johannesburg,tshwane,ethekwini,ekurhuleni,nelson_mandela_bay
#
# DeedsWeb Direct API (DRDLR — Chief Registrar of Deeds)
# Provides: registered owner, title deed, transfer history, bonds — R18/query
# Register at: deedsweb.deeds.gov.za — R217 one-time fee
# Contact: 012 401 9323
DEEDSWEB_USERNAME=
DEEDSWEB_PASSWORD=
DEEDSWEB_WSDL_URL=https://deedsweb.deeds.gov.za/services/DeedsWebService?wsdl
DEEDSWEB_COST_PER_QUERY=18
#
# WinDeed Browser Automation (beta.windeed.co.za — optional, expensive)
# Only needed if DeedsWeb credentials unavailable. R50+/search, requires voucher balance
WINDEED_USERNAME=
WINDEED_PASSWORD=
